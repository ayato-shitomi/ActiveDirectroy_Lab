# AWS AD Lab Environment - Example Configuration
# Copy this file to terraform.tfvars and customize the values

# Required: Number of pods to deploy (1-10)
pod_count = 1

# Required: Bastion SSH password (for ubuntu user)
bastion_password = "P@ssw0rd123!"

# Required: Default Windows Administrator password
# Must be at least 8 characters, include uppercase, lowercase, number, and special character
admin_password = "P@ssw0rd123!"

# Optional: Individual machine Administrator passwords (defaults to admin_password)
# dc_admin_password      = "P@ssw0rd123!"
# filesrv_admin_password = "P@ssw0rd123!"
# client_admin_password  = "P@ssw0rd123!"

# Required: Domain Administrator and DSRM password
domain_password = "P@ssw0rd123!"

# Required: CIDR block allowed for SSH access to Bastion
# Use your IP address for security (e.g., "203.0.113.0/32")
# Use "0.0.0.0/0" for open access (not recommended for production)
allowed_ssh_cidr = "0.0.0.0/0"

# Optional: AWS region (default: ap-northeast-1)
# aws_region = "ap-northeast-1"

# Optional: Active Directory domain settings
# domain_name    = "lab.local"
# domain_netbios = "LAB"

# Optional: Instance types
# bastion_instance_type = "t3.small"
# dc_instance_type      = "t3.medium"
# filesrv_instance_type = "t3.medium"
# client_instance_type  = "t3.medium"

# Optional: VPC CIDR (default: 10.100.0.0/16)
# vpc_cidr = "10.100.0.0/16"

# Optional: AD User passwords (default: P@ssw0rd!)
# user_password_tanaka   = "P@ssw0rd!"
# user_password_hasegawa = "P@ssw0rd!"
# user_password_saitou   = "P@ssw0rd!"

# Optional: CLIENT local user password (default: P@ssw0rd!)
# client_local_user_ueda_password = "P@ssw0rd!"
